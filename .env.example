# Required: OpenRouter API key for LLM chat functionality.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Massive (Polygon.io) API key for real market data.
# If not set (or left empty), the built-in market simulator is used.
# Recommended to leave empty for most users.
MASSIVE_API_KEY=

# Optional: Set to "true" to use deterministic mock LLM responses.
# Used in E2E tests (LLM_MOCK=true) so tests don't require an API key.
LLM_MOCK=false

# Optional: Override the default chat model chain (comma-separated, tried in order).
# Each model is attempted; on 429 rate-limit or 404 model-not-found the next is tried.
# Default chain:
#   openrouter/meta-llama/llama-3.3-70b-instruct:free,
#   openrouter/google/gemma-2-9b-it:free,
#   openrouter/deepseek/deepseek-chat:free,
#   openrouter/mistralai/mistral-small-3.1-24b-instruct:free
# Browse current free models at https://openrouter.ai/models
FINALLY_LLM_MODEL=
